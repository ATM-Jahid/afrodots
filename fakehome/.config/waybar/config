        "format-charging": "{capacity}\n",
        "format-plugged": "{capacity}\n",
        "format-excess": "9X\n{icon}",
        // "full-at": 95, // makes the capacity 100 at >= <value>
        "format-full": "9Y\n{icon}", // works only when charging & at 100
        "format-icons": ["", "", "", "", ""]
